<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. -->
    <style name="Base.Theme.EnigmaBridge" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/material_blue_200</item>
        <item name="colorPrimaryVariant">@color/material_blue_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/material_blue_200</item>
        <item name="colorSecondaryVariant">@color/material_blue_500</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Default accent color -->
        <item name="accentColor">@color/accent_color_state_list</item>
    </style>

    <style name="Theme.EnigmaBridge" parent="Base.Theme.EnigmaBridge" />

    <style name="Theme.EnigmaBridge.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.EnigmaBridge.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="Theme.EnigmaBridge.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

    <style name="Theme.EnigmaBridge.Dialog" parent="Theme.EnigmaBridge">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowMinWidthMajor">@android:dimen/dialog_min_width_major</item>
        <item name="android:windowMinWidthMinor">@android:dimen/dialog_min_width_minor</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowBackground">?android:attr/colorBackground</item>
    </style>

    <!-- Overlay style to apply dynamic accent color -->
    <style name="OverlayAccentColor" parent="ThemeOverlay.Material3.DynamicColors.DayNight">
        <item name="colorPrimary">?attr/accentColor</item>
        <item name="colorPrimaryVariant">?attr/accentColor</item>
        <item name="colorSecondary">?attr/accentColor</item>
        <item name="colorSecondaryVariant">?attr/accentColor</item>
    </style>

    <!-- Themes for different accent colors -->
    <style name="AppTheme_Base" parent="Theme.EnigmaBridge">
        <item name="accentColor">@color/accent_color_state_list</item>
    </style>

    <style name="AppTheme_Green" parent="AppTheme_Base">
        <item name="colorPrimary">@color/material_green_200</item>
        <item name="colorPrimaryVariant">@color/material_green_700</item>
        <item name="colorSecondary">@color/material_green_200</item>
        <item name="colorSecondaryVariant">@color/material_green_500</item>
    </style>

    <style name="AppTheme_Orange" parent="AppTheme_Base">
        <item name="colorPrimary">@color/material_orange_200</item>
        <item name="colorPrimaryVariant">@color/material_orange_700</item>
        <item name="colorSecondary">@color/material_orange_200</item>
        <item name="colorSecondaryVariant">@color/material_orange_500</item>
    </style>

    <style name="AppTheme_Red" parent="AppTheme_Base">
        <item name="colorPrimary">@color/material_red_200</item>
        <item name="colorPrimaryVariant">@color/material_red_700</item>
        <item name="colorSecondary">@color/material_red_200</item>
        <item name="colorSecondaryVariant">@color/material_red_500</item>
    </style>

    <style name="AppTheme_Blue" parent="AppTheme_Base">
        <item name="colorPrimary">@color/material_blue_200</item>
        <item name="colorPrimaryVariant">@color/material_blue_700</item>
        <item name="colorSecondary">@color/material_blue_200</item>
        <item name="colorSecondaryVariant">@color/material_blue_500</item>
    </style>

    <!-- Dialog themes for different accent colors -->
    <style name="AppTheme_Green_Dialog" parent="AppTheme_Green">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowMinWidthMajor">@android:dimen/dialog_min_width_major</item>
        <item name="android:windowMinWidthMinor">@android:dimen/dialog_min_width_minor</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowBackground">?android:attr/colorBackground</item>
    </style>

    <style name="AppTheme_Orange_Dialog" parent="AppTheme_Orange">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowMinWidthMajor">@android:dimen/dialog_min_width_major</item>
        <item name="android:windowMinWidthMinor">@android:dimen/dialog_min_width_minor</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowBackground">?android:attr/colorBackground</item>
    </style>

    <style name="AppTheme_Red_Dialog" parent="AppTheme_Red">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowMinWidthMajor">@android:dimen/dialog_min_width_major</item>
        <item name="android:windowMinWidthMinor">@android:dimen/dialog_min_width_minor</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowBackground">?android:attr/colorBackground</item>
    </style>

    <style name="AppTheme_Blue_Dialog" parent="AppTheme_Blue">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowMinWidthMajor">@android:dimen/dialog_min_width_major</item>
        <item name="android:windowMinWidthMinor">@android:dimen/dialog_min_width_minor</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowBackground">?android:attr/colorBackground</item>
    </style>

</resources>