<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        tools:context=".ui.main.MainActivity">

        <!-- Receiver Settings Header -->
        <TextView
            android:id="@+id/header_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Status Checks -->
        <ImageView
            android:id="@+id/statusEnigmaIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginTop="24dp"
            android:src="@drawable/ic_help"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/header_title"
            app:tint="?attr/colorOnSurface"
            android:contentDescription="@null" />

        <!-- Engima Connection Indicator -->
        <TextView
            android:id="@+id/statusEnigmaText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/status_enigma_unchecked"
            android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
            app:layout_constraintBottom_toBottomOf="@+id/statusEnigmaIcon"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/statusEnigmaIcon"
            app:layout_constraintTop_toTopOf="@+id/statusEnigmaIcon" />

        <!-- TV Browser Installed Indicator Icon -->
        <ImageView
            android:id="@+id/statusTvBrowserIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginTop="16dp"
            android:src="@drawable/ic_help"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/statusEnigmaIcon"
            app:tint="?attr/colorOnSurface"
            android:contentDescription="@null" />

        <!-- TV Browser Installed Indicator -->
        <TextView
            android:id="@+id/statusTvBrowserText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/status_tvbrowser_unchecked"
            android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
            app:layout_constraintBottom_toBottomOf="@+id/statusTvBrowserIcon"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/statusTvBrowserIcon"
            app:layout_constraintTop_toTopOf="@+id/statusTvBrowserIcon" />

        <!-- Periodic Sync Indicator Icon -->
        <ImageView
            android:id="@+id/statusTimerSyncIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginTop="16dp"
            android:src="@drawable/ic_error"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/statusTvBrowserIcon"
            app:tint="?attr/colorOnSurface"
            android:contentDescription="@null" />

        <!-- Periodic Sync Indicator -->
        <TextView
            android:id="@+id/statusTimerSyncText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/status_periodic_sync_disabled"
            android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
            app:layout_constraintBottom_toBottomOf="@+id/statusTimerSyncIcon"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/statusTimerSyncIcon"
            app:layout_constraintTop_toTopOf="@+id/statusTimerSyncIcon" />

        <!-- Notification Permission Indicator -->
        <ImageView
            android:id="@+id/statusNotificationIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginTop="16dp"
            android:src="@drawable/ic_error"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/statusTimerSyncIcon"
            app:tint="?attr/colorOnSurface"
            android:contentDescription="@null" />

        <!-- Notification Permission Indicator Hint -->
        <TextView
            android:id="@+id/statusNotificationText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/status_notifications_disabled"
            android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
            app:layout_constraintBottom_toBottomOf="@+id/statusNotificationIcon"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/statusNotificationIcon"
            app:layout_constraintTop_toTopOf="@+id/statusNotificationIcon" />

        <!-- Last Sync Timestamp Indicator -->
        <ImageView
            android:id="@+id/statusLastSyncIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginTop="16dp"
            android:src="@drawable/ic_update"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/statusNotificationIcon"
            app:tint="?attr/colorOnSurface"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/statusLastSyncText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/status_last_sync_never"
            android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
            app:layout_constraintBottom_toBottomOf="@+id/statusLastSyncIcon"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/statusLastSyncIcon"
            app:layout_constraintTop_toTopOf="@+id/statusLastSyncIcon" />


        <!-- Horizontal Divider -->
        <View
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="?attr/colorOutlineVariant"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/statusLastSyncText" />





        <!-- Receiver Settings Button -->
        <Button
            android:id="@+id/button_receiver_settings"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/button_receiver_settings"
            app:layout_constraintTop_toBottomOf="@+id/divider"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Timer Button -->
        <Button
            android:id="@+id/button_view_timers"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/view_scheduled_timers"
            app:layout_constraintEnd_toEndOf="@+id/button_receiver_settings"
            app:layout_constraintStart_toStartOf="@+id/button_receiver_settings"
            app:layout_constraintTop_toBottomOf="@+id/button_receiver_settings" />

        <!-- App Settings Button -->
        <Button
            android:id="@+id/button_settings"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/button_settings"
            app:layout_constraintEnd_toEndOf="@+id/button_view_timers"
            app:layout_constraintStart_toStartOf="@+id/button_view_timers"
            app:layout_constraintTop_toBottomOf="@+id/button_view_timers" />

        <!-- Test Connection Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_test_connection"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="@string/button_test_connection"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/button_settings"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintVertical_bias="1.0"/>


    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
