<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <group
        android:translateX="54"
        android:translateY="54">
        <!-- The scale is reduced to prevent clipping on round icons -->
        <group
            android:scaleX="0.6"
            android:scaleY="0.6">

            <!-- Receiver Box Body -->
            <path
                android:fillColor="#FFFFFF"
                android:pathData="M-40,8 H40 V24 H-40 Z" />

            <!-- Status Lights and Vents -->
            <path
                android:fillColor="#424242"
                android:pathData="M-32,12 h4 v8 h-4z
                             M-24,12 h4 v8 h-4z
                             M-16,12 h4 v8 h-4z"/>

            <!-- Power Button (Reverted to a path to fix validation error) -->
            <path
                android:fillColor="#424242"
                android:pathData="M 22,12 a 4,4 0 1,1 0,8 a 4,4 0 1,1 0,-8 z"/>

            <!-- The Suspension Bridge -->
            <!-- Towers -->
            <path
                android:fillColor="#FFFFFF"
                android:pathData="M-25,8 V-25 h6 V8 Z
                                 M19,8 V-25 h6 V8 Z" />

            <!-- Roadway -->
            <path
                android:strokeColor="#FFFFFF"
                android:strokeWidth="4"
                android:pathData="M-40,-5 H40"/>

            <!-- Suspension Cables -->
            <path
                android:strokeColor="#FFFFFF"
                android:strokeWidth="2"
                android:fillColor="#00000000"
                android:pathData="M-22,-24 C -10,-13 10,-13 22,-24"/>

            <!-- Vertical suspender ropes -->
            <path
                android:strokeColor="#FFFFFF"
                android:strokeWidth="1.5"
                android:pathData=" M-15,-5 V-20
                                M-5,-5 V-16
                                M5,-5 V-16
                                M15,-5 V-20 "/>

        </group>
    </group>
</vector>

